{% extends 'base.html.twig' %}

{% block title %}Foedex | Entrar{% endblock %}

{% block body %}
    {% include 'components/_nav.html.twig' %}
    <main class="container page-shell narrow">
        {% include 'components/_flash.html.twig' %}
        <section class="panel">
            <h1>Iniciar sesión</h1>

            {% if error %}
                <div class="flash flash-error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
            {% endif %}

            <form method="post">
                <label for="username">Email</label>
                <input id="username" type="email" name="_username" value="{{ last_username }}" required autofocus>

                <label for="password">Contraseña</label>
                <input id="password" type="password" name="_password" required>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <button class="button" type="submit">Entrar</button>
            </form>
        </section>
    </main>
{% endblock %}
