{% extends 'base.html.twig' %}

{% block title %}Foedex | Historial de {{ page.currentTitle }}{% endblock %}

{% block body %}
    {% include 'components/_nav.html.twig' %}
    <main class="container page-shell">
        <section class="panel">
            <div class="panel-header">
                <h1>Historial de {{ page.currentTitle }}</h1>
                <a class="button button-secondary" href="{{ path('app_page_show', {slug: page.currentSlug}) }}">Volver a la página</a>
            </div>

            <div class="stack-list">
                {% for revision in revisions %}
                    <article class="list-card">
                        <h2>Revisión #{{ revision.revisionNumber }}</h2>
                        <div class="meta-row">
                            <span>{{ revision.author.displayName }}</span>
                            <span>{{ revision.createdAt|date('d/m/Y H:i') }}</span>
                        </div>
                        {% if revision.changeSummary %}
                            <p>{{ revision.changeSummary }}</p>
                        {% endif %}
                        <div class="inline-actions">
                            <a href="{{ path('app_page_revision', {slug: page.currentSlug, revision: revision.revisionNumber}) }}">Ver detalle</a>
                            {% if app.user %}
                                <form method="post" action="{{ path('app_page_restore', {slug: page.currentSlug, revision: revision.revisionNumber}) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('restore_revision_' ~ page.id ~ '_' ~ revision.revisionNumber) }}">
                                    <button type="submit">Restaurar</button>
                                </form>
                            {% endif %}
                        </div>
                    </article>
                {% endfor %}
            </div>
        </section>
    </main>
{% endblock %}
