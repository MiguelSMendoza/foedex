{% extends 'base.html.twig' %}

{% block title %}Foedex | {{ category.name }}{% endblock %}

{% block body %}
    {% include 'components/_nav.html.twig' %}
    <main class="container page-shell">
        <section class="panel">
            <h1>{{ category.name }}</h1>
            {% if category.description %}
                <p class="lead">{{ category.description }}</p>
            {% endif %}
            <div class="stack-list">
                {% for page in category.pages %}
                    <article class="list-card">
                        <h2><a href="{{ path('app_page_show', {slug: page.currentSlug}) }}">{{ page.currentTitle }}</a></h2>
                        <p>{{ page.currentExcerpt ?: page.currentMarkdown|slice(0, 160) ~ '...' }}</p>
                    </article>
                {% else %}
                    <p class="empty-state">No hay páginas en esta categoría todavía.</p>
                {% endfor %}
            </div>
        </section>
    </main>
{% endblock %}
